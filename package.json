{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "herdr-workflows",
  "version": "0.0.0-development",
  "description": "Linear YAML workflow runner for herdr panes — shell, open, agent, herdr steps.",
  "keywords": [
    "agent",
    "ai",
    "herdr-plugin",
    "workflow",
    "yaml"
  ],
  "homepage": "https://github.com/aorumbayev/herdr-workflows",
  "bugs": {
    "url": "https://github.com/aorumbayev/herdr-workflows/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aorumbayev/herdr-workflows.git"
  },
  "bin": {
    "herdr-workflows": "./src/cli.ts",
    "hwf": "./src/cli.ts"
  },
  "files": [
    "src",
    "tsconfig.json",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "scripts": {
    "test": "bun test ./test",
    "schema": "bun scripts/generate-schema.ts",
    "build": "bun build --compile --outfile=bin/herdr-workflows src/cli.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "install:dev": "bun run build && herdr plugin unlink herdr-workflows >/dev/null 2>&1; herdr plugin link \"$PWD\" && node scripts/install-keybindings.mjs && node scripts/install-cli.mjs && herdr server reload-config",
    "prepare": "git config core.hooksPath .githooks",
    "verify:lint": "verifyx lint",
    "verify:format": "verifyx format",
    "verify:check-types": "verifyx check-types",
    "verify": "verifyx --no-tests",
    "verify:unused-code": "verifyx unused-code --max-warnings 0",
    "verify:duplicate-code": "verifyx duplicate-code --max-warnings 0",
    "verify:complexity": "verifyx complexity",
    "verify:comments": "verifyx comments --pushback",
    "verify:circular-deps": "skott --displayMode=raw --showCircularDependencies --exitCodeOnCircularDependencies=1",
    "verify:hardcoded-colors": "verifyx hardcoded-colors"
  },
  "dependencies": {
    "@opentui/core": "0.4.5",
    "zod": "4.1.8"
  },
  "devDependencies": {
    "@makerx/verify": "1.3.0-beta.13",
    "@tsconfig/bun": "1.0.10",
    "@types/bun": "1.3.13",
    "jscpd": "5.0.12",
    "knip": "6.27.0",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "skott": "0.35.11",
    "typescript": "5.8.2",
    "vitepress": "1.6.4"
  }
}
